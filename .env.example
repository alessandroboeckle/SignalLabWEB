# Signal Lab Environment Variables

# Application Name
VITE_APP_NAME=Signal Lab

# API Configuration (if backend is added later)
VITE_API_URL=http://localhost:3000/api

# Feature Flags
VITE_ENABLE_FFT=true
VITE_ENABLE_EXPORT=true
VITE_ENABLE_IMPORT=true

# Storage Configuration
VITE_STORAGE_QUOTA_MB=5
VITE_AUTO_SAVE=true

# Debug Mode
VITE_DEBUG=false
